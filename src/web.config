<?xml version="1.0" encoding="UTF-8"?>
<configuration>

	<appSettings>

		<!-- REQUIRED. Environment label (DEV, UAT, PROD) shown on every page header chip. -->
		<add key="CPlatform.Environment" value="UAT" />

		<!-- ================================================================
		     Module tiles — Default.aspx landing page
		     Each module has two keys:
		       CPlatform.Tile.<n>.Url          — full URL for this environment
		       CPlatform.Tile.<n>.Environments — comma-separated list of environments
		                                         that show this tile.
		                                         Omit the key (or leave blank) to show
		                                         in all environments.
		     A tile is hidden if its Url is blank/missing regardless of environment.

		     Hero CTA buttons also use URL keys so they stay consistent with tiles.
		     ================================================================ -->

		<add key="CPlatform.Tile.LPPI.Url"          value="LPPI/LPPI_Admin.aspx" />
		<add key="CPlatform.Tile.LPPI.Environments" value="UAT,PROD" />

		<add key="CPlatform.Tile.COA.Url"           value="http://YOUR-APP-SERVER/COASearch.asp" />
		<add key="CPlatform.Tile.COA.Environments"  value="UAT,PROD" />

		<add key="CPlatform.Tile.eJET.Url"          value="http://YOUR-APP-SERVER/eJet.aspx" />
		<add key="CPlatform.Tile.eJET.Environments" value="UAT" />

		<add key="CPlatform.Tile.eJETMulti.Url"          value="http://YOUR-APP-SERVER/eJet_Multi.aspx" />
		<add key="CPlatform.Tile.eJETMulti.Environments" value="UAT" />

		<add key="CPlatform.Tile.DFGForms.Url"          value="http://YOUR-APP-SERVER/path/to/Default.aspx" />
		<add key="CPlatform.Tile.DFGForms.Environments" value="UAT" />

		<add key="CPlatform.Tile.CAPS.Url"          value="http://YOUR-APP-SERVER/" />
		<add key="CPlatform.Tile.CAPS.Environments" value="DEV,UAT,PROD" />

		<!-- Hero Call to Action (CTA) buttons — kept in config for the same reason as tile URLs -->
		<add key="CPlatform.HeroCta.Primary.Url"   value="LPPI/LPPI_Admin.aspx" />
		<add key="CPlatform.HeroCta.Primary.Label" value="LPPI Review" />
		<add key="CPlatform.HeroCta.Ghost.Url"     value="http://YOUR-APP-SERVER/COASearch.asp" />
		<add key="CPlatform.HeroCta.Ghost.Label"   value="COA Search" />

		<!-- ================================================================
		     LPPI Review module settings
		     ================================================================ -->

		<!-- Reviewer page deadline behaviour. -->
		<add key="LPPI.DefaultDueDays" value="14" />
		<add key="LPPI.ReminderWindowDays" value="3" />

		<!-- Used to build the absolute URL in outgoing emails. -->
		<add key="LPPI.BaseUrl" value="http://YOUR-CPLATFORM-SERVER/" />

		<!-- Set to "true" in production to enable email sending.
		     When false (UAT/dev), the Send button is disabled and only
		     email preview is available. -->
		<add key="LPPI.ProductionMode" value="false" />

		<add key="LPPI.SmtpHost" value="YOUR-SMTP-RELAY" />
		<add key="LPPI.SmtpPort" value="25" />
		<add key="LPPI.SmtpEnableSsl" value="false" />
		<add key="LPPI.SmtpUser" value="" />
		<add key="LPPI.SmtpPassword" value="" />
		<add key="LPPI.MailFrom" value="noreply@your-domain.example" />
		<add key="LPPI.MailFromName" value="LPPI Review" />

		<!-- Support / feedback mailbox.
		     To: LPPI inbox. CC: DFSPI group.
		     Used in the page header "Feedback & support" button and the email footer. -->
		<add key="LPPI.SupportMailboxTo" value="noreply@your-domain.example" />
		<add key="LPPI.SupportMailboxCc" value="support@your-domain.example" />

		<!-- Shown on the "link not available" error page. -->
		<add key="LPPI.SupportContact" value="LPPI Support — support@your-domain.example" />

		<!-- LPPI Review: SAP Fiori base URL for deep links. -->
		<add key="LPPI.SapBaseUrl" value="https://YOUR-SAP-SERVER:44300" />

	</appSettings>

	<system.web>
		<globalization requestEncoding="utf-8" responseEncoding="utf-8" fileEncoding="utf-8" culture="en-AU" uiCulture="en-AU" />

		<!-- Allow up to ~100MB uploads (value in KB) -->
		<httpRuntime maxRequestLength="102400" executionTimeout="3000" />

		<!--
		debug="false" for production. Flip to true only on a developer box.
		Leaving it true in prod hurts performance and disables some optimisations in the ASP.NET pipeline.
		-->
		<compilation debug="true" targetFramework="4.8" />

		<!-- Never expose tracing on a deployed site -->
		<trace enabled="false" />

		<!--
		customErrors Off while bedding the site in so real errors are visible.
		Once stable, change to: <customErrors mode="RemoteOnly" />
		-->
		<customErrors mode="Off" />
	</system.web>

	<system.webServer>
		<asp appAllowClientDebug="true" enableParentPaths="true" scriptErrorSentToBrowser="true">
			<limits scriptTimeout="00:59:00" bufferingLimit="104857600" maxRequestEntityAllowed="104857600" />
		</asp>

		<!--
		Detailed errors while bedding in. Once stable, change to: <httpErrors errorMode="DetailedLocalOnly">
		-->
		<httpErrors errorMode="Detailed">
			<remove statusCode="403" subStatusCode="-1" />
		</httpErrors>

		<!-- Make Default.aspx the site root document -->
		<defaultDocument>
			<files>
				<clear />
				<add value="Default.aspx" />
			</files>
		</defaultDocument>

		<!-- Standard hardening headers, plus removing the ASP.NET banner -->
		<httpProtocol>
			<customHeaders>
				<add name="X-Content-Type-Options" value="nosniff" />
				<add name="X-Frame-Options" value="SAMEORIGIN" />
				<add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
				<add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
				<remove name="X-Powered-By" />
			</customHeaders>
		</httpProtocol>

		<!-- Block direct download of source, config and connection files. -->
		<security>
			<requestFiltering>
				<!-- 104857600 bytes = 100 MB -->
				<requestLimits maxAllowedContentLength="104857600" />
				<hiddenSegments>
					<add segment="Database" />
				</hiddenSegments>
				<fileExtensions>
					<add fileExtension=".json" allowed="false" />
					<add fileExtension=".udl" allowed="false" />
				</fileExtensions>
			</requestFiltering>
			<authentication>
				<anonymousAuthentication enabled="false" />
			</authentication>
		</security>
	</system.webServer>

</configuration>
