<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appSettings>
        <!--
            Optional explicit override for the CPLATFORM environment label.
            Leave commented out to let Default.aspx auto-detect from the IIS site name.
            Valid values: DEV, UAT, PROD
        -->
        <add key="CPlatform.Environment" value="UAT" />

  <!-- Where to read incoming BODS extracts from. -->
  <add key="LPPI.SourcePath" value="\\....\OUTPUT_MIRROR" />

  <!-- Where to write the generated upload file (a copy is also streamed to the browser). -->
  <add key="LPPI.ExportPath" value="\\...\INPUT_MIRROR" />

  <!-- Environment label for the header chip: DEV / UAT / PROD -->
  <add key="LPPI.Environment" value="UAT" />

  <!-- Reviewer page deadline behaviour. -->
  <add key="LPPI.DefaultDueDays"     value="14" />
  <add key="LPPI.ReminderWindowDays" value="3" />

  <!-- Used to build the absolute URL in outgoing emails.
       If omitted the email will derive it from the current request, but for
       cron / background reminders you should set this explicitly. -->
  <add key="LPPI.BaseUrl" value="http://.....au" />

  <!-- SMTP — the LPPI module does not use the legacy tblCC_SmtpConfig table.
       It reads SMTP settings from here so it can be swapped per-environment
       without touching the database. -->
  <add key="LPPI.SmtpHost"      value="smtprelay....au" />
  <add key="LPPI.SmtpPort"      value="25" />
  <add key="LPPI.SmtpEnableSsl" value="false" />
  <add key="LPPI.SmtpUser"      value="" />
  <add key="LPPI.SmtpPassword"  value="" />
  <add key="LPPI.MailFrom"      value="noreply.cplatform....au" />
  <add key="LPPI.MailFromName"  value="DFG CPLATFORM" />

  <!-- Shown on the "link not available" error page. -->
  <add key="LPPI.SupportContact" value="DFG Finance Support — finance.support@d....au" />

    </appSettings>

    <system.web>

	<globalization
		requestEncoding="utf-8"
		responseEncoding="utf-8"
		fileEncoding="utf-8"
		culture="en-AU"
		uiCulture="en-AU"
	/>

        <!-- Allow up to ~100MB uploads (value in KB), matches CAPS forms -->
        <httpRuntime maxRequestLength="102400" executionTimeout="3000" />

        <!--
            debug="false" for production. Flip to true only on a developer box.
            Leaving it true in prod hurts performance and disables some
            optimisations in the ASP.NET pipeline.
        -->
        <compilation debug="true" targetFramework="4.8" />

        <!-- Never expose tracing on a deployed site -->
        <trace enabled="false" />

        <!--
            customErrors Off while bedding the site in so real errors are visible.
            Once stable, change to: <customErrors mode="RemoteOnly" />
        -->
        <customErrors mode="Off" />
    </system.web>

    <system.webServer>

        <asp appAllowClientDebug="true" enableParentPaths="true" scriptErrorSentToBrowser="true">
            <limits scriptTimeout="00:59:00" bufferingLimit="67108864" maxRequestEntityAllowed="30000000" />
        </asp>

        <!--
            Detailed errors while bedding in. Once stable, change to:
            <httpErrors errorMode="DetailedLocalOnly">
        -->
        <httpErrors errorMode="Detailed">
            <remove statusCode="403" subStatusCode="-1" />
        </httpErrors>

        <!-- Make Default.aspx (the new CPLATFORM landing) the site root document -->
        <defaultDocument>
            <files>
                <clear />
                <add value="Default.aspx" />
            </files>
        </defaultDocument>

        <!-- Standard hardening headers, plus removing the ASP.NET banner -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
                <remove name="X-Powered-By" />
            </customHeaders>
        </httpProtocol>

        <!--
            Block direct download of source, config and connection files.
            ASP.NET already blocks .cs by default but being explicit is cheap
            insurance, and the .json / .udl / .config entries are the important
            ones because the project keeps secrets in those.
        -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="Database" />
                </hiddenSegments>
                <fileExtensions>
                    <add fileExtension=".json"   allowed="false" />
                    <add fileExtension=".udl"    allowed="false" />
                </fileExtensions>
            </requestFiltering>
        </security>

    </system.webServer>


</configuration>